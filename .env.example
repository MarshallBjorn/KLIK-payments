# ============================================
# Django
# ============================================
DJANGO_SETTINGS_MODULE=core.settings.dev
SECRET_KEY=change-me-to-something-secure-min-50-chars-long # pragma: allowlist secret
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,web

# ============================================
# PostgreSQL
# ============================================
# Te zmienne są używane PRZEZ obraz postgres do inicjalizacji bazy
POSTGRES_DB=klik
POSTGRES_USER=klik
POSTGRES_PASSWORD=change-me

# Te zmienne są używane PRZEZ Django do połączenia
DATABASE_URL=postgres://klik:change-me@db:5432/klik # pragma: allowlist secret

# ============================================
# Redis
# ============================================
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ============================================
# KLIK — konfiguracja domenowa
# ============================================
# TTL kodu w sekundach (z dokumentacji: 120s w produkcji)
KLIK_CODE_TTL_SECONDS=120

# Interwały sesji rozliczeniowych per strefa (w minutach)
# Default produkcja: 1440 (24h). Dla demo: 2-15 min
SESSION_INTERVAL_MINUTES_PL=1440
SESSION_INTERVAL_MINUTES_EU=1440
SESSION_INTERVAL_MINUTES_UK=1440
SESSION_INTERVAL_MINUTES_US=1440

# Timeout dispatcher → RTGS w sekundach
RTGS_TIMEOUT_SECONDS=30

# URLe RTGS mocków (per strefa)
SORBNET3_URL=http://rtgs-mock:9000/sorbnet3
TARGET2_URL=http://rtgs-mock:9000/target2
CHAPS_URL=http://rtgs-mock:9000/chaps
FEDNOW_URL=http://rtgs-mock:9000/fednow
